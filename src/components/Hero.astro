---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-proporcional-desktop">
    <div class="container hero-content">
      <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
        {site.descricaoCurta}
      </p>

      <div class="hero-cta fade-up" style="animation-delay: 0.9s">
        <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
        <a href="#sobre" class="btn">Sobre o espetáculo</a>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span>Role para descobrir</span>
        <div class="scroll-line"></div>
      </div>
    </div>
  </div>

  <div class="hero-container-mobile">
    <!-- Imagem como elemento img (não background) — assim aparece inteira sem corte -->
    <img src="/images/backdrop-mobile.png" alt="Misa Criolla com Jean William" class="hero-image-mobile" />

    <div class="container hero-content-mobile">
      <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
        {site.descricaoCurta}
      </p>

      <div class="hero-cta fade-up" style="animation-delay: 0.9s">
        <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
        <a href="#sobre" class="btn">Sobre o espetáculo</a>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span>Role para descobrir</span>
        <div class="scroll-line"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* A seção externa apenas segura o bloco e aceita o corte radical se a tela achatar */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    overflow: hidden;
    background-color: rgba(31, 20, 12, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ESTRUTURA DE PROPORÇÃO RÍGIDA (DESKTOP) */
  .hero-proporcional-desktop {
    position: relative;
    width: 100%;
    height: 0;
    padding-top: 56.25%; /* Proporção exata de 16:9 do backdrop.jpg */
    background-image: linear-gradient(180deg, transparent 50%, rgba(31, 20, 12, 0.95) 85%, rgba(31, 20, 12, 1) 100%),
                      url('/images/backdrop.jpg');
    background-size: cover;
    background-position: center top;
    min-width: 100vw;
    min-height: 100dvh;
  }

  /* CONTEÚDO CRAVADO COM AJUSTE FINO DE ALTURA */
  .hero-content {
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 720px;
    text-align: center;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--cor-texto);
    max-width: 560px;
    margin: 0 auto;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.9);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* Desliga o container mobile por padrão no desktop */
  .hero-container-mobile {
    display: none;
  }

  /* LAYOUT MOBILE — imagem inteira no topo + texto/botões embaixo */
  @media (max-width: 768px) {
    .hero {
      /* Solta a altura: agora cresce o necessário pra caber imagem + conteúdo */
      min-height: 100dvh;
      align-items: stretch;
    }

    .hero-proporcional-desktop {
      display: none;
    }

    .hero-container-mobile {
      display: flex;
      flex-direction: column;
      width: 100%;
      min-height: 100dvh;
      position: relative;
      background-color: rgba(31, 20, 12, 1);
    }

    /* Imagem ocupa o topo, mostrando inteira (sem corte) */
    .hero-image-mobile {
      display: block;
      width: 100%;
      height: auto;
      max-height: 70dvh;
      object-fit: contain;
      object-position: top center;
    }

    .hero-content-mobile {
      position: relative;
      z-index: 2;
      width: 100%;
      padding-top: 1.5rem;
      padding-bottom: 2rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      flex: 1;
      justify-content: center;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1.5rem;
      text-shadow: none;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1.5rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }

    .hero-scroll {
      margin-top: 0.5rem;
    }
  }
</style>
