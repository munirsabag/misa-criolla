---
import { site } from '../data/site.js';
const anoAtual = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3 class="footer-titulo">
          <span>Misa</span>
          <span class="italico">Criolla</span>
        </h3>
        <p class="footer-tagline">{site.tagline}</p>
      </div>

      <div class="footer-contato">
        <p class="footer-label">Atendimento à imprensa</p>
        <p>{site.assessoria}</p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        <p>{site.telefone}</p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {anoAtual} Misa Criolla. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--cor-fundo-gradient-1);
    border-top: 1px solid var(--cor-borda);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-titulo {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .footer-titulo .italico {
    font-style: italic;
  }

  .footer-tagline {
    color: var(--cor-texto-suave);
    font-style: italic;
  }

  .footer-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cor-acento);
    margin-bottom: 0.75rem;
  }

  .footer-contato p {
    color: var(--cor-texto-suave);
    margin-bottom: 0.25rem;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--cor-borda);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: var(--cor-texto-muted);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
