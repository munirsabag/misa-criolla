---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Por padrão, mostra a versão desktop e esconde a mobile */
  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 65%,
      rgba(31, 20, 12, 0.85) 88%,
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* Conteúdo posicionado embaixo, sem encavalar com o título da imagem */
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 720px;
    padding-bottom: 3rem;
    text-align: center;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--cor-texto);
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /*