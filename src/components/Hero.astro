---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100dvh; /* Força a seção a ter exatamente a altura da tela visual */
    min-height: 650px; /* Impede que o site achate demais em telas muito baixas */
    overflow: hidden;
    background-color: rgba(31, 20, 12, 1);
    
    /* Nova estrutura: O layout vira um grid vertical fixo */
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Empurra o conteúdo para a parte de baixo */
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* Aceita o corte da imagem conforme o navegador redimensiona */
    object-position: center 20%; /* Ajusta o foco do corte um pouco abaixo do topo para tentar segurar o título */
  }

  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(31, 20, 12, 0.4) 50%,
      rgba(31, 20, 12, 0.95) 85%, /* Escurecimento pesado e estático para engolir qualquer sobra de imagem */
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* O conteúdo agora é estático em relação à base da seção */
  .hero-content {
    position: relative; /* Sai do absolute para respeitar o fluxo do flex-end */
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: 4rem; /* Distância fixa da borda inferior da tela */
    text-align: center;
    z-index: 2;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--cor-texto);
    max-width: 560px;
    margin: 0 auto;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5); /* Garante leitura se a imagem vazar por baixo */
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-fit: cover;
      object-position: center top;
    }

    .hero-content {
      padding-bottom: 2rem;
      gap: 1.5rem;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1rem;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }
  }
</style>