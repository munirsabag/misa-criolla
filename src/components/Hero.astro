---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh; /* Evita quebra com barras de navegadores mobile */
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Por padrão, mostra a versão desktop e esconde a mobile */
  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(31, 20, 12, 0.1) 40%,  /* Sombra sutil sob o título do backdrop */
      rgba(31, 20, 12, 0.85) 75%, /* Garante contraste para o texto dinâmico */
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* Conteúdo confinado à metade inferior da tela para proteger o título da imagem */
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 850px; /* Um pouco mais largo para o texto ocupar menos linhas verticais */
    height: 100%;
    max-height: 42dvh; /* Teto máximo: o texto nunca invade os 58% superiores da tela */
    padding-bottom: 3rem;
    text-align: center;
    z-index: 2;
    
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Empurra o bloco de conteúdo para a base da área protegida */
    align-items: center;
    gap: 1.75rem;
  }

  .hero-descricao {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--cor-texto);
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* TELAS INTERMEDIÁRIAS: Trata notebooks menores e tablets antes de quebrar o layout */
  @media (max-width: 1100px) {
    .hero-content {
      max-height: 46dvh; /* Dá um leve respiro extra para telas mais achatadas */
      gap: 1.25rem;
    }
    .hero-descricao {
      font-size: 1rem;
      max-width: 580px;
    }
    .hero-scroll {
      margin-top: 0.75rem;
    }
  }

  /* MOBILE: usa a arte vertical (stories) */
  @media (max-width: 768px) {
    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-position: center top;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 50%,
        rgba(31, 20, 12, 0.85) 75%,
        rgba(31, 20, 12, 1) 100%
      );
    }

    .hero-content {
      max-height: 50dvh; /* No mobile a arte vertical costuma deixar mais espaço abaixo */
      padding-bottom: 2rem;
      gap: 1.25rem;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1rem;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }

    .hero-scroll {
      margin-top: 0.5rem;
    }
  }
</style>