---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    background-color: rgba(31, 20, 12, 1); /* Garante que o fundo preencha as laterais ou bases sem emendas */
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Garante que o conteúdo nasça ancorado na base */
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; /* Mantém a proporção exata da imagem sem dar zoom ou cortar o título */
    object-position: center top; /* Fixa o topo da imagem alinhado ao topo da seção */
  }

  /* Por padrão, mostra a versão desktop e esconde a mobile */
  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(31, 20, 12, 0) 50%,
      rgba(31, 20, 12, 0.7) 80%,
      rgba(31, 20, 12, 1) 100
    );
  }

  /* Bloco de conteúdo centralizado */
  .hero-content {
    position: relative;
    width: 100%;
    max-width: 800px; /* Um pouco mais largo para acomodar o texto em menos linhas */
    margin: 0 auto;
    padding-bottom: 3rem;
    text-align: center;
    z-index: 2;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--cor-texto);
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* TELAS INTERMEDIÁRIAS: Ajustes finos de texto para notebooks */
  @media (max-width: 1100px) {
    .hero-content {
      gap: 1.25rem;
      padding-bottom: 2.5rem;
    }
    .hero-descricao {
      font-size: 1rem;
      max-width: 540px;
    }
  }

  /* MOBILE: Transiciona para a arte vertical (stories) */
  @media (max-width: 768px) {
    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-fit: cover; /* No mobile, a arte vertical geralmente funciona melhor cobrindo a tela */
      object-position: center top;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 50%,
        rgba(31, 20, 12, 0.85) 75%,
        rgba(31, 20, 12, 1) 100
      );
    }

    .hero-content {
      height: 100dvh;
      justify-content: flex-end;
      max-height: 48dvh; /* Mantém o texto bem seguro na metade inferior do celular */
      padding-bottom: 2rem;
      gap: 1.25rem;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1rem;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }

    .hero-scroll {
      margin-top: 0.5rem;
    }
  }
</style>