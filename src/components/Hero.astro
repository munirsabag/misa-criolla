---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Por padrão, mostra a versão desktop e esconde a mobile */
  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 65%,
      rgba(31, 20, 12, 0.85) 88%,
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* Conteúdo posicionado embaixo, sem encavalar com o título da imagem */
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 720px;
    padding-bottom: 3rem;
    text-align: center;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--cor-texto);
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* "Role para descobrir" */
  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* MOBILE FIX DEFENSIVO */
  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      display: block;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
    }

    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top; /* Garante o rosto do cantor e o título legíveis no topo */
    }

    .hero-overlay {
      background: rgba(31, 20, 12, 0.4); /* Escurece o fundo de leve para dar contraste geral */
    }

    .hero-content {
      position: absolute;
      bottom: 110px; /* Fixa o bloco de conteúdo bem acima da régua de logos da imagem */
      left: 50%;
      transform: translateX(-50%);
      width: 90%; /* Deixa uma margem elegante nas laterais */
      max-height: 45vh; /* Impede o texto de subir demais e cobrir o rosto do Jean */
      overflow-y: auto; /* Se a tela for muito pequena, o texto vira rolável por segurança */
      background: rgba(31, 20, 12, 0.85); /* Caixa escura translúcida isolando o texto dos logos */
      padding: 1.5rem 1.25rem;
      border-radius: 12px;
      gap: 1.25rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    }

    .hero-descricao {
      font-size: 0.88rem; /* Fonte compacta e elegante */
      line-height: 1.5;
      padding: 0;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      gap: 0.65rem;
    }

    .hero-cta .btn {
      width: 100%;
      padding: 0.75rem 1rem; /* Botões ligeiramente mais compactos para poupar espaço vertical */
    }

    /* Esconde a linha de scroll no mobile para economizar espaço precioso de tela */
    .hero-scroll {
      display: none;
    }
  }
</style>