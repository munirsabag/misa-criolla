---
import { parceiros } from '../data/site.js';
---

<section id="parceiros" class="parceiros">
  <div class="container">
    <div class="parceiros-header">
      <p class="eyebrow">Quem viabiliza</p>
      <h2 class="parceiros-titulo">
        <span class="italico">parceiros</span>
      </h2>
      <svg class="flourish" viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M10,15 Q50,5 100,15 T190,15"
          stroke="currentColor"
          stroke-width="1"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
    </div>

    <!-- Faixa branca unificada com todos os logos -->
    <div class="parceiros-faixa">
      <!-- À esquerda: destaque (Lei Rouanet sem título) -->
      {parceiros.destaque.length > 0 && (
        <div class="parceiros-destaque">
          {parceiros.destaque.map((item) => (
            <a href={item.site} target="_blank" rel="noopener" class="logo-link" title={item.nome}>
              <img src={item.logo} alt={item.nome} loading="lazy" />
            </a>
          ))}
        </div>
      )}

      <!-- Demais grupos com título -->
      <div class="parceiros-grupos">
        {parceiros.grupos.map((grupo) => (
          <div class="parceiros-grupo">
            <p class="parceiros-categoria">{grupo.titulo}</p>
            <div class="parceiros-logos">
              {grupo.items.map((item) => (
                <a href={item.site} target="_blank" rel="noopener" class="logo-link" title={item.nome}>
                  <img src={item.logo} alt={item.nome} loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .parceiros-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .parceiros-titulo {
    line-height: 1;
    font-style: italic;
    color: var(--cor-acento-quente);
  }

  .flourish {
    color: var(--cor-acento);
    margin: 1rem auto 0;
    display: block;
  }

  /* Faixa branca unificada — todos os logos sobre fundo branco */
  .parceiros-faixa {
    background: #ffffff;
    padding: 3rem;
    border-radius: 4px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: start;
  }

  .parceiros-destaque {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-right: 3rem;
    border-right: 1px solid rgba(0, 0, 0, 0.1);
    align-self: center;
  }

  .parceiros-destaque .logo-link {
    padding: 0;
  }

  .parceiros-destaque img {
    max-height: 70px;
    max-width: 200px;
  }

  .parceiros-grupos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .parceiros-grupo {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .parceiros-categoria {
    font-family: var(--fonte-texto);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #5a4530;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .parceiros-logos {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    width: 100%;
  }

  .logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60px;
    width: 100%;
    transition: opacity var(--transicao), transform var(--transicao);
  }

  .logo-link:hover {
    opacity: 0.75;
    transform: translateY(-2px);
  }

  .logo-link img {
    max-height: 50px;
    max-width: 140px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .parceiros-faixa {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem;
    }

    .parceiros-destaque {
      padding-right: 0;
      padding-bottom: 2rem;
      border-right: none;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      justify-content: center;
    }

    .parceiros-grupos {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }
</style>
