/* Conteúdo ancorado na base, usando padding proporcional à largura da tela */
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 900px; /* Alarga o container para o texto ocupar menos linhas */
    height: 100%;
    
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Garante que o ponto de partida é a base absoluta */
    align-items: center;
    gap: 1.5rem;
    
    /* Cria um teto rígido usando a largura da viewport (vw). 
       Isso faz a área de proteção encolher proporcionalmente junto com a imagem de fundo */
    padding-top: 35vw; 
    padding-bottom: 4rem;
    z-index: 2;
    box-sizing: border-box;
  }

  .hero-descricao {
    font-size: clamp(0.95rem, 1.2vw, 1.15rem); /* Diminui fluidamente se a tela diminuir */
    line-height: 1.6;
    color: var(--cor-texto);
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  /* ... as regras do scroll-line e keyframes continuam iguais ... */

  /* TELAS INTERMEDIÁRIAS: Quando o monitor começa a estreitar e a imagem de fundo "espreme" o título */
  @media (max-width: 1100px) {
    .hero-content {
      padding-top: 42vw; /* Aumenta a barreira no topo proporcionalmente ao corte do cover */
      padding-bottom: 3rem;
      gap: 1rem;
    }
    .hero-descricao {
      max-width: 540px;
    }
  }

  /* MOBILE: Mantém a estrutura para a arte vertical */
  @media (max-width: 768px) {
    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-position: center top;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 50%,
        rgba(31, 20, 12, 0.85) 75%,
        rgba(31, 20, 12, 1) 100%
      );
    }

    .hero-content {
      padding-top: 0; /* Reseta o comportamento baseado em largura no mobile */
      justify-content: flex-end;
      height: 100%;
      max-height: 48dvh; /* Convecciona o texto na metade inferior do celular */
      padding-bottom: 2.5rem;
      gap: 1.25rem;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1.5rem;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1.5rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }
  }