---
import { fichaTecnica } from '../data/site.js';
---

<section id="ficha-tecnica" class="ficha">
  <div class="container">
    <div class="ficha-header">
      <p class="eyebrow">Quem faz</p>
      <h2 class="ficha-titulo">
        <span>ficha</span>
        <span class="italico">técnica</span>
      </h2>
      <svg class="flourish" viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M10,15 Q50,5 100,15 T190,15"
          stroke="currentColor"
          stroke-width="1"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
    </div>

    <div class="ficha-lista">
      {fichaTecnica.map((pessoa, index) => (
        <article class={`pessoa ${index % 2 === 1 ? 'invertido' : ''}`}>
          {pessoa.foto && (
            <div class="pessoa-foto-wrapper">
              <img src={pessoa.foto} alt={pessoa.nome} class="pessoa-foto" loading="lazy" />
            </div>
          )}

          <div class="pessoa-info">
            <p class="pessoa-numero">{String(index + 1).padStart(2, '0')}</p>
            <h3 class="pessoa-nome">{pessoa.nome}</h3>
            <p class="pessoa-funcao">{pessoa.funcao}</p>
            <p class="pessoa-bio">{pessoa.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ficha-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .ficha-titulo {
    line-height: 1;
  }

  .ficha-titulo span {
    display: inline-block;
  }

  .ficha-titulo .italico {
    font-style: italic;
    color: var(--cor-acento-quente);
    margin-left: 0.5rem;
  }

  .flourish {
    color: var(--cor-acento);
    margin: 1rem auto 0;
    display: block;
  }

  .ficha-lista {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .pessoa {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    align-items: center;
  }

  .pessoa.invertido {
    grid-template-columns: 1fr 280px;
  }

  .pessoa.invertido .pessoa-foto-wrapper {
    order: 2;
  }

  .pessoa-foto-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--cor-fundo-claro);
    border: 1px solid var(--cor-borda);
  }

  .pessoa-foto-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(31, 20, 12, 0.4) 100%);
    pointer-events: none;
  }

  .pessoa-foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s ease;
    filter: saturate(0.85) contrast(1.05);
  }

  .pessoa:hover .pessoa-foto {
    transform: scale(1.03);
  }

  .pessoa-numero {
    font-family: var(--fonte-display);
    font-size: 1.25rem;
    color: var(--cor-acento);
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .pessoa-nome {
    font-family: var(--fonte-display);
    font-size: 2rem;
    color: var(--cor-texto);
    margin-bottom: 0.5rem;
    font-weight: 500;
    line-height: 1.1;
  }

  .pessoa-funcao {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-acento);
    margin-bottom: 1.25rem;
  }

  .pessoa-bio {
    color: var(--cor-texto-suave);
    font-size: 1rem;
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .pessoa,
    .pessoa.invertido {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .pessoa.invertido .pessoa-foto-wrapper {
      order: 0;
    }

    .pessoa-foto-wrapper {
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
