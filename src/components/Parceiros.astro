---
// Parceiros (versão com cabeçalho, no rodapé do site):
// - Desktop: usa a régua-imagem (mesma da barra de cima) com hotspots clicáveis
// - Mobile: layout estruturado em código, empilhado (legível)
---

<section id="parceiros" class="parceiros">
  <div class="container">
    <div class="parceiros-header">
      <p class="eyebrow">Quem viabiliza</p>
      <h2 class="parceiros-titulo">
        <span class="italico">parceiros</span>
      </h2>
      <svg class="flourish" viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M10,15 Q50,5 100,15 T190,15"
          stroke="currentColor"
          stroke-width="1"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
      <p class="parceiros-convite">Clique nos logos para conhecer nossos parceiros</p>
    </div>
  </div>

  <!-- VERSÃO DESKTOP: imagem da régua + hotspots clicáveis transparentes -->
  <div class="parceiros-imagem-wrapper">
    <img src="/images/regua-parceiros.png" alt="Parceiros: Lei Rouanet, Ampliart, Usina Santo Ângelo, Dama Infra, Voccalia, Ministério da Cultura, Governo do Brasil" class="parceiros-imagem" />

    <!-- Hotspots invisíveis sobre cada logo -->
    <a href="https://www.gov.br/cultura/pt-br/assuntos/lei-rouanet" target="_blank" rel="noopener" class="hotspot" style="left: 3%; width: 10%;" title="Lei Rouanet" aria-label="Lei Rouanet"></a>
    <a href="https://ampliart.art.br" target="_blank" rel="noopener" class="hotspot" style="left: 17%; width: 10%;" title="Ampliart Difusão Cultural" aria-label="Ampliart Difusão Cultural"></a>
    <a href="https://usangelo.com.br" target="_blank" rel="noopener" class="hotspot" style="left: 32%; width: 18%;" title="Usina Santo Ângelo" aria-label="Usina Santo Ângelo"></a>
    <a href="https://damainfra.com.br" target="_blank" rel="noopener" class="hotspot" style="left: 54%; width: 8%;" title="Dama Infra" aria-label="Dama Infra"></a>
    <a href="https://voccalia.org" target="_blank" rel="noopener" class="hotspot" style="left: 62%; width: 10%;" title="Instituto Voccalia" aria-label="Instituto Voccalia"></a>
    <a href="https://www.gov.br/cultura" target="_blank" rel="noopener" class="hotspot" style="left: 76%; width: 12%;" title="Ministério da Cultura" aria-label="Ministério da Cultura"></a>
    <a href="https://www.gov.br" target="_blank" rel="noopener" class="hotspot" style="left: 89%; width: 9%;" title="Governo do Brasil" aria-label="Governo do Brasil"></a>
  </div>

  <!-- VERSÃO MOBILE: estrutura legível empilhada (só aparece em telas pequenas) -->
  <div class="parceiros-mobile">
    <div class="container">
      <div class="parceiros-mobile-destaque">
        <a href="https://www.gov.br/cultura/pt-br/assuntos/lei-rouanet" target="_blank" rel="noopener" class="logo-link-mobile" title="Lei Rouanet">
          <img src="/images/logos/rouanet.png" alt="Lei Rouanet" loading="lazy" />
        </a>
      </div>

      <div class="parceiros-mobile-grupos">
        <div class="parceiros-mobile-grupo">
          <p class="parceiros-categoria-mobile">Produção</p>
          <a href="https://ampliart.art.br" target="_blank" rel="noopener" class="logo-link-mobile" title="Ampliart">
            <img src="/images/logos/ampliart.png" alt="Ampliart" loading="lazy" />
          </a>
        </div>

        <div class="parceiros-mobile-grupo">
          <p class="parceiros-categoria-mobile">Patrocínio</p>
          <a href="https://usangelo.com.br" target="_blank" rel="noopener" class="logo-link-mobile" title="Usina Santo Ângelo">
            <img src="/images/logos/usina-santo-angelo.png" alt="Usina Santo Ângelo" loading="lazy" />
          </a>
        </div>

        <div class="parceiros-mobile-grupo">
          <p class="parceiros-categoria-mobile">Apoio</p>
          <div class="parceiros-mobile-multilogo">
            <a href="https://damainfra.com.br" target="_blank" rel="noopener" class="logo-link-mobile" title="Dama Infra">
              <img src="/images/logos/dama-infra.png" alt="Dama Infra" loading="lazy" />
            </a>
            <a href="https://voccalia.org" target="_blank" rel="noopener" class="logo-link-mobile" title="Voccalia">
              <img src="/images/logos/voccalia.png" alt="Voccalia" loading="lazy" />
            </a>
          </div>
        </div>

        <div class="parceiros-mobile-grupo">
          <p class="parceiros-categoria-mobile">Realização</p>
          <a href="https://www.gov.br/cultura" target="_blank" rel="noopener" class="logo-link-mobile" title="Ministério da Cultura">
            <img src="/images/logos/ministerio-cultura.png" alt="Ministério da Cultura — Governo do Brasil" loading="lazy" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .parceiros-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .parceiros-titulo {
    line-height: 1;
    font-style: italic;
    color: var(--cor-acento-quente);
  }

  .flourish {
    color: var(--cor-acento);
    margin: 1rem auto 0;
    display: block;
  }

  /* Frase de convite abaixo do título */
  .parceiros-convite {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--cor-texto-suave);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  /* ============================================
     VERSÃO DESKTOP — IMAGEM + HOTSPOTS CLICÁVEIS
     ============================================ */
  .parceiros-imagem-wrapper {
    position: relative;
    background: #ffffff;
    width: 100%;
    padding: 1.5rem clamp(1rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .parceiros-imagem {
    display: block;
    width: 100%;
    max-width: 1600px;
    height: auto;
  }

  /* Cada hotspot é um <a> transparente posicionado sobre o logo na imagem.
     Ocupa toda a altura útil da faixa pra capturar o clique sem precisar
     de precisão milimétrica do usuário. Totalmente invisível —
     o cursor "mãozinha" já indica que é clicável. */
  .hotspot {
    position: absolute;
    top: 15%;
    height: 70%;
    background: transparent;
    z-index: 2;
    cursor: pointer;
  }

  /* No mobile, esconde a imagem desktop e os hotspots */
  .parceiros-mobile {
    display: none;
  }

  /* ============================================
     MOBILE — Layout legível, empilhado
     ============================================ */
  @media (max-width: 900px) {
    .parceiros-imagem-wrapper {
      display: none;
    }

    .parceiros-mobile {
      display: block;
      background: #ffffff;
      padding: 2rem 1.5rem;
      margin-top: 1rem;
    }

    .parceiros-mobile-destaque {
      display: flex;
      justify-content: center;
      padding-bottom: 2rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .parceiros-mobile-grupos {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .parceiros-mobile-grupo {
      text-align: center;
    }

    .parceiros-categoria-mobile {
      font-family: var(--fonte-texto);
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #5a4530;
      margin-bottom: 1rem;
      font-weight: 500;
    }

    .parceiros-mobile-multilogo {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }

    .logo-link-mobile {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 60px;
      transition: opacity var(--transicao), transform var(--transicao);
    }

    .logo-link-mobile:hover {
      opacity: 0.75;
      transform: translateY(-2px);
    }

    .logo-link-mobile img {
      max-height: 60px;
      max-width: 220px;
      width: auto;
      height: auto;
      object-fit: contain;
    }
  }
</style>
