---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/backdrop.jpg"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-desktop"
      loading="eager"
    />
    <img
      src="/images/backdrop-mobile.png"
      alt="Misa Criolla com Jean William"
      class="hero-image hero-image-mobile"
      loading="eager"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
      {site.descricaoCurta}
    </p>

    <div class="hero-cta fade-up" style="animation-delay: 0.9s">
      <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
      <a href="#sobre" class="btn">Sobre o espetáculo</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>Role para descobrir</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-color: rgba(31, 20, 12, 1);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(31, 20, 12, 0.2) 45%,
      rgba(31, 20, 12, 0.85) 75%,
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* BLOCO ULTRAESTÁTICO: Centralizado horizontalmente no topo da imagem,
     descendo usando exclusivamente 'vw'. Ele vai se mover exatamente no mesmo
     ritmo e proporção que o título impresso na foto ("MISA CRIOLLA") */
  .hero-content {
    position: absolute;
    top: 36vw; /* Distância matemática cravada em relação ao topo da imagem */
    left: 50%;
    transform: translateX(-50%);
    
    /* Larguras e preenchimentos baseados na largura da tela */
    width: 60vw; 
    max-width: 800px;
    text-align: center;
    z-index: 2;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2vw; /* Distanciamento proporcional entre os blocos */
  }

  .hero-descricao {
    font-size: clamp(0.95rem, 1.15vw, 1.15rem); /* Tamanho da fonte encolhe junto com o monitor */
    line-height: 1.6;
    color: var(--cor-texto);
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5vw;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* MOBILE: Retorna para o fluxo isolado vertical do celular */
  @media (max-width: 768px) {
    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-fit: cover;
      object-position: center top;
    }

    .hero-content {
      top: auto;
      bottom: 0;
      width: 100%;
      height: 100dvh;
      max-height: 48dvh;
      justify-content: flex-end;
      padding-bottom: 2rem;
      gap: 1.25rem;