---
import { site } from '../data/site.js';
---

<section class="hero">
  <div class="hero-container-fixo">
    <div class="hero-bg">
      <img
        src="/images/backdrop.jpg"
        alt="Misa Criolla com Jean William"
        class="hero-image hero-image-desktop"
        loading="eager"
      />
      <img
        src="/images/backdrop-mobile.png"
        alt="Misa Criolla com Jean William"
        class="hero-image hero-image-mobile"
        loading="eager"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="container hero-content">
      <p class="hero-descricao fade-up" style="animation-delay: 0.6s">
        {site.descricaoCurta}
      </p>

      <div class="hero-cta fade-up" style="animation-delay: 0.9s">
        <a href="#agenda" class="btn btn-primary">Ver agenda de shows</a>
        <a href="#sobre" class="btn">Sobre o espetáculo</a>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span>Role para descobrir</span>
        <div class="scroll-line"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* O container externo garante que a seção ocupe a tela, mas aceita o corte radical */
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-color: rgba(31, 20, 12, 1);
    
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Este bloco interno trava a proporção. Imagem e texto agora vivem na mesma "caixa" */
  .hero-container-fixo {
    position: relative;
    width: 100%;
    height: 100%;
    /* Ajuste o aspect-ratio abaixo para o formato real do seu backdrop.jpg se necessário */
    aspect-ratio: 16 / 9; 
    
    /* Força a caixa a dar um "zoom/cover" inteiro se o navegador distorcer, cortando as sobras */
    min-width: 100%;
    min-height: 100%;
    object-fit: cover;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-image-mobile {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(31, 20, 12, 0.3) 50%,
      rgba(31, 20, 12, 0.9) 85%,
      rgba(31, 20, 12, 1) 100%
    );
  }

  /* O conteúdo agora está cravado usando coordenadas fixas baseadas na caixa da imagem */
  .hero-content {
    position: absolute;
    bottom: 8%; /* Fica preso a exatamente 8% de distância da base da IMAGEM, não da tela */
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 720px;
    text-align: center;
    z-index: 2;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-descricao {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--cor-texto);
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .hero-scroll span {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cor-texto-muted);
  }

  .scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--cor-acento), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* MOBILE: Quebra a regra para usar o formato vertical de celular */
  @media (max-width: 768px) {
    .hero-container-fixo {
      aspect-ratio: auto; /* Desfaz o formato de cinema no celular */
    }

    .hero-image-desktop {
      display: none;
    }

    .hero-image-mobile {
      display: block;
      object-fit: cover;
      object-position: center top;
    }

    .hero-content {
      bottom: 0;
      height: 100dvh;
      max-height: 48dvh;
      justify-content: flex-end;
      padding-bottom: 2rem;
      gap: 1.25rem;
    }

    .hero-descricao {
      font-size: 0.9rem;
      line-height: 1.5;
      padding: 0 1rem;
    }

    .hero-cta {
      flex-direction: column;
      width: 100%;
      padding: 0 1rem;
      gap: 0.75rem;
    }

    .hero-cta .btn {
      width: 100%;
    }
  }
</style>